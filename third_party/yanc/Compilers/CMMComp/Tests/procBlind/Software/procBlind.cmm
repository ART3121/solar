// Blind sparse deconvolution in C+- (SAPHO) for the procBlind processor.
//
// This is the C+- counterpart of CPPComp's examples/test36.cpp: the SAME
// deterministic FISTA blind deconvolution, sample-for-sample. Both target the
// YANC core (32-bit word, 23-bit mantissa, 8-bit exponent) and must produce the
// same output on the same input:
//
//   h_hat * 1e6  ->  9257 32370 470346 1000000 566933 149177 32725
//
// Algorithm (fixed, deterministic - no BIC sweep, no early stopping):
//   M = 7, C = 3, LAM = 1, OUTER = 40, XIT = 20, HIT = 5, BT = 15, HSTEP = 1e-5.
//   project clamps h to [0,1] and pins h[C] = 1; update_h backtracks keeping the
//   best candidate (not first-improvement); shoulder seed h = [.. .5 1 .5 ..].
//
// Sizes (compile-time fixed; arrays cannot be function parameters in C+-):
//   N  = 40   (waveform length)
//   LX = 34   (sparse-sequence length, N - M + 1)
//
// I/O mirrors test36's in()/out() so the same Verilator harness drives it:
//   input  : N samples scaled by GAIN_IN = 30000, reconstructed as
//            fin(0) / 30000.0 ( = (float)b / GAIN_IN in test36; fin does the
//            int->float convert ). N is fixed at 40 - no leading count word.
//   output : 7 words, h_hat[j] * GAIN_OUT + 0.5 truncated to int (F2I) on port 0
//            ( = (int)(h_hat[j] * 1e6 + 0.5) in test36 ).
//
// C+- restrictions handled:
//   - arrays cannot be function parameters -> all arrays are global, one helper
//     per (source, kernel) pairing used by conv_full in test36.
//   - no for-over-arrays / no +=, -=, *=    -> while loops, explicit assignment.
//   - no (float)/(int) casts                -> fin() converts in; assigning a
//     float expression to out()/an int does F2I.
//   - no exponent literals (1e-5)           -> written long-form (0.00001).

#PRNAME procBlind
#NUBITS 32
#NBMANT 23
#NBEXPO 8
#NDSTAC 10
#SDEPTH 10
#NUIOIN 1
#NUIOOU 1

// ----------------------------------------------------------------------------
// Globals --------------------------------------------------------------------
// ----------------------------------------------------------------------------

float y[40];          // input waveform, filled at runtime via fin()

float x_hat[34];      // sparse sequence estimate
float h_hat[7];       // pulse estimate

float s_z     [34];   // FISTA momentum point
float s_x_prev[34];   // previous x for momentum
float s_grad_x[34];   // gradient wrt x
float s_conv  [40];   // full convolution / residual scratch

float s_h_cand[7];    // backtracking candidate pulse
float s_h_best[7];    // best pulse found while backtracking
float s_grad_h[7];    // gradient wrt h

// ----------------------------------------------------------------------------
// Projection: clamp h to [0,1], pin h[C] = 1  (C = 3) -------------------------
// ----------------------------------------------------------------------------

void project_h_hat(int dummy)
{
    int k = 0;
    while (k < 7)
    {
        if (h_hat[k] < 0.0) h_hat[k] = 0.0;
        if (h_hat[k] > 1.0) h_hat[k] = 1.0;
        k++;
    }
    h_hat[3] = 1.0;
}

void project_h_cand(int dummy)
{
    int k = 0;
    while (k < 7)
    {
        if (s_h_cand[k] < 0.0) s_h_cand[k] = 0.0;
        if (s_h_cand[k] > 1.0) s_h_cand[k] = 1.0;
        k++;
    }
    s_h_cand[3] = 1.0;
}

// ----------------------------------------------------------------------------
// Lipschitz constant of grad_x: for non-negative h, ||H||_op = ||h||_1,
// so L = (sum h)^2, floored away from zero. ----------------------------------
// ----------------------------------------------------------------------------

float lipschitz_x(int dummy)
{
    float s = 0.0;
    int   k = 0;
    while (k < 7) { s = s + h_hat[k]; k++; }
    float L = s * s;
    if (L < 0.000000000001) L = 0.000000000001;
    return L;
}

// ----------------------------------------------------------------------------
// Full convolution s_conv[0..N) = conv_full(source[0..LX), kernel[0..M)) ------
// One helper per (source, kernel) pair test36's conv_full is called with. -----
// ----------------------------------------------------------------------------

void conv_zh(int dummy)               // conv_full(s_z, h_hat)
{
    int n = 0;
    while (n < 40) { s_conv[n] = 0.0; n++; }
    int ii = 0;
    while (ii < 34)
    {
        float zi = s_z[ii];
        int   j  = 0;
        while (j < 7)
        {
            s_conv[ii+j] = s_conv[ii+j] + zi * h_hat[j];
            j++;
        }
        ii++;
    }
}

void conv_xh(int dummy)               // conv_full(x_hat, h_hat)
{
    int n = 0;
    while (n < 40) { s_conv[n] = 0.0; n++; }
    int ii = 0;
    while (ii < 34)
    {
        float xi = x_hat[ii];
        int   j  = 0;
        while (j < 7)
        {
            s_conv[ii+j] = s_conv[ii+j] + xi * h_hat[j];
            j++;
        }
        ii++;
    }
}

void conv_x_hcand(int dummy)          // conv_full(x_hat, s_h_cand)
{
    int n = 0;
    while (n < 40) { s_conv[n] = 0.0; n++; }
    int ii = 0;
    while (ii < 34)
    {
        float xi = x_hat[ii];
        int   j  = 0;
        while (j < 7)
        {
            s_conv[ii+j] = s_conv[ii+j] + xi * s_h_cand[j];
            j++;
        }
        ii++;
    }
}

// ----------------------------------------------------------------------------
// Residual: s_conv <- s_conv - y ---------------------------------------------
// ----------------------------------------------------------------------------

void residual_sub_y(int dummy)
{
    int n = 0;
    while (n < 40) { s_conv[n] = s_conv[n] - y[n]; n++; }
}

// sum(s_conv^2); assumes the residual is already in s_conv.
float sum_residual_sq(int dummy)
{
    float s = 0.0;
    int   n = 0;
    while (n < 40) { s = s + s_conv[n]*s_conv[n]; n++; }
    return s;
}

// ----------------------------------------------------------------------------
// Valid-mode correlations ----------------------------------------------------
// ----------------------------------------------------------------------------

// s_grad_x[0..LX) = corr_valid(s_conv, h_hat)
void correlate_residual_h(int dummy)
{
    int n = 0;
    while (n < 34)
    {
        float s = 0.0;
        int   k = 0;
        while (k < 7) { s = s + s_conv[n+k] * h_hat[k]; k++; }
        s_grad_x[n] = s;
        n++;
    }
}

// s_grad_h[0..M) = corr_valid(s_conv, x_hat)
void correlate_residual_x(int dummy)
{
    int n = 0;
    while (n < 7)
    {
        float s = 0.0;
        int   k = 0;
        while (k < 34) { s = s + s_conv[n+k] * x_hat[k]; k++; }
        s_grad_h[n] = s;
        n++;
    }
}

// ----------------------------------------------------------------------------
// FISTA for x with fixed h: XIT fixed iterations, lambda = 1 ------------------
// ----------------------------------------------------------------------------

void fista_x(int dummy)
{
    int ii = 0;
    while (ii < 34) { s_z[ii] = x_hat[ii]; s_x_prev[ii] = x_hat[ii]; ii++; }

    float t        = 1.0;
    float L        = lipschitz_x(0);
    float step     = 1.0 / L;
    float step_lam = step * 1.0;       // LAM = 1.0

    int it = 0;
    while (it < 20)
    {
        // gradient at z: grad_x = corr_valid(conv(z,h) - y, h)
        conv_zh(0);
        residual_sub_y(0);
        correlate_residual_h(0);

        // proximal step: x = max(0, z - step*grad - step*lam)
        ii = 0;
        while (ii < 34)
        {
            float v = s_z[ii] - step * s_grad_x[ii] - step_lam;
            if (v < 0.0) v = 0.0;
            x_hat[ii] = v;
            ii++;
        }

        // Nesterov momentum
        float tn  = 0.5 * (1.0 + sqrt(1.0 + 4.0 * t * t));
        float mom = (t - 1.0) / tn;
        ii = 0;
        while (ii < 34)
        {
            float xi = x_hat[ii];
            s_z[ii]      = xi + mom * (xi - s_x_prev[ii]);
            s_x_prev[ii] = xi;
            ii++;
        }
        t = tn;

        it++;
    }
}

// ----------------------------------------------------------------------------
// Projected-gradient update of h with best-candidate backtracking ------------
// ----------------------------------------------------------------------------

void update_h(int dummy)
{
    project_h_hat(0);

    int it = 0;
    while (it < 5)
    {
        // residual and gradient of the data term wrt h
        conv_xh(0);
        residual_sub_y(0);
        float dt = 0.5 * sum_residual_sq(0);

        correlate_residual_x(0);
        s_grad_h[3] = 0.0;

        float best_dt = dt;
        int   ii = 0;
        while (ii < 7) { s_h_best[ii] = h_hat[ii]; ii++; }

        float trial = 0.00001;         // HSTEP
        int   bt    = 0;
        while (bt < 15)
        {
            ii = 0;
            while (ii < 7) { s_h_cand[ii] = h_hat[ii] - trial * s_grad_h[ii]; ii++; }
            project_h_cand(0);

            conv_x_hcand(0);
            residual_sub_y(0);
            float cdt = 0.5 * sum_residual_sq(0);

            if (cdt < best_dt)
            {
                best_dt = cdt;
                ii = 0;
                while (ii < 7) { s_h_best[ii] = s_h_cand[ii]; ii++; }
            }
            trial = trial * 0.5;
            bt++;
        }

        ii = 0;
        while (ii < 7) { h_hat[ii] = s_h_best[ii]; ii++; }

        it++;
    }

    project_h_hat(0);
}

// ----------------------------------------------------------------------------
// Alternating minimization: OUTER passes of (fista_x, update_h) ---------------
// ----------------------------------------------------------------------------

void fit(int dummy)
{
    int ii = 0;
    while (ii < 34) { x_hat[ii] = 0.0; ii++; }
    ii = 0;
    while (ii < 7) { h_hat[ii] = 0.0; ii++; }

    // shoulder seed: h[C-1] = 0.5, h[C] = 1.0, h[C+1] = 0.5  (C = 3)
    h_hat[2] = 0.5;
    h_hat[3] = 1.0;
    h_hat[4] = 0.5;

    int it = 0;
    while (it < 40)
    {
        fista_x(0);
        update_h(0);
        it++;
    }
}

// ----------------------------------------------------------------------------
// Top level: read input, fit, emit h_hat * 1e6 -------------------------------
// ----------------------------------------------------------------------------

void main()
{
    int n = 0;
    while (n < 40)
    {
        y[n] = fin(0) / 30000.0;   // = (float)b / GAIN_IN
        n++;
    }

    fit(0);

    int j = 0;
    while (j < 7)
    {
        int r = h_hat[j] * 1000000.0 + 0.5;   // F2I truncates -> (int)(h*1e6 + 0.5)
        out(0, r);
        j++;
    }
}
