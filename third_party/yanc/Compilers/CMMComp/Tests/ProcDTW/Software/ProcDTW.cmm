#PRNAME ProcDTW
#NUBITS 32
#NDSTAC 5
#SDEPTH 5
#NUIOIN 3
#NUIOOU 3
#NBMANT 23
#NBEXPO 8

int len_ref, len_data;
int dtw[75][75];
int k, j, menor, val_final,cont;
int data_ref[75], data[75];


void main()
{
    //if(in(0) == 0) //On general reset:
    //{
        len_ref = 75;
        cont    = 0;
        while(cont < 75) // Fill vector 1 with 0s if len_ref is 0 (for the first case)
        {
            data_ref[cont] = 0;
            cont++;
        }
        out(2, 10);
    //}
    //else //normal processing
    //{
        out(2,-122);
        return;

#PRACA
out(2,-123);
        k = 0;

        len_data = in(2);        // Length of vector 2

        cont = 0;

        while(cont < 75) // Fill vector 2
        {
            if (len_data > cont)
            {
                data[cont]= in(1);
            }
            else
            {
                data[cont] = 0;
            }
            cont++;
        }
        out(2,-124);
        out(2,k);
        out(2,len_data);

        while (k < len_data) // rows of the dtw matrix
        {
            j = 0;
            out(2,-125);
            while (j < len_ref)
            {
                if(k == 0 && j == 0)        // First position k=0, j=0
                {
                    dtw[k][j] = abs(data[k] - data_ref[j]);
                    out(2, dtw[k][j]);
                }
                else
                {
                    if(k == 0 && j > 0)         // First row
                    {
                        dtw[k][j] = abs(data[k] - data_ref[j]) + dtw[k][j-1];
                        out(2, dtw[k][j]);
                    }
                }

                if (k > 0 && j == 0)             // First column
                {
                    dtw[k][j] = abs(data[k] - data_ref[j]) + dtw[k - 1][j];
                    out(2, dtw[k][j]);
                }
                else
                {
                    if (k > 0 && j > 0)         // For the remaining positions
                    {
                        menor = dtw[k-1][j];
                        out(2, menor);
                        if (dtw[k][j-1] < menor)
                        {
                            menor = dtw[k][j-1];
                            out(2, menor);
                        }
                        out(2, dtw[k-1][j-1]);
                        if (dtw[k-1][j-1] < menor)
                        {
                            menor = dtw[k-1][j-1];
                            out(2, menor);
                        }
                        dtw[k][j] = abs(data[k] - data_ref[j]) + menor;
                        out(2, dtw[k][j]);
                    }
                }
                j++;
            }
            k++;
        }

        val_final = dtw[k-1][j-1];

        if(dtw[k-1][j-1]>36000)  //If there is novelty
        {
            cont    = 0;           // Reset the counter
            len_ref = len_data;        // Update the length
            while(cont < 75)    // Update vector 1
            {
                data_ref[cont]= data[cont];
                cont++ ;
            }
        }

        out(1,val_final);
        out(2, 36000);

    //}
    out(0,1);
}
