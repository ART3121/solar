#PRNAME cmm_dowhile
#NUBITS 16
#NDSTAC 8
#SDEPTH 8
#NUIOIN 1
#NUIOOU 1
#NBMANT 10
#NBEXPO 5
#NUGAIN 128

// do { } while () coverage, validated by the SIMULATED OUTPUT VALUES. The body
// runs first and the condition is tested at the bottom, so the body always runs
// at least once. break and continue work via the same stacks as while/for; a
// do-while continue lands on the bottom test (re-evaluates the condition).
//
//   D1 body-runs-once  : cond false up front, body still runs       -> 10
//   D2 normal loop     : iterate while k<3                          -> 20 21 22
//   D3 break           : leave the loop when k==2                   -> 30 31
//   D4 continue        : skip k==3 but still re-test at the bottom  -> 41 42 44 45
//   D5 nested          : inner do-while, inner break only           -> 50 51 60 61 70 71
//
// Expected per iteration: 10 20 21 22 30 31 41 42 44 45 50 51 60 61 70 71

void main()
{
    int k; int n;
    while (1)
    {
        // D1 -- the body runs once even though the condition is false going in
        k = 10;
        do { out(0, k); k = k + 1; } while (k < 5);

        // D2 -- ordinary bottom-tested loop
        k = 0;
        do { out(0, 20 + k); k = k + 1; } while (k < 3);

        // D3 -- break leaves the do-while
        k = 0;
        do { if (k == 2) break; out(0, 30 + k); k = k + 1; } while (k < 10);

        // D4 -- continue skips the rest of the body but still hits the bottom
        // test, so the loop keeps going (and the index keeps advancing)
        k = 0;
        do { k = k + 1; if (k == 3) continue; out(0, 40 + k); } while (k < 5);

        // D5 -- nested do-while; the inner break exits only the inner loop
        k = 0;
        do {
            n = 0;
            do { if (n == 2) break; out(0, 50 + k * 10 + n); n = n + 1; } while (n < 5);
            k = k + 1;
        } while (k < 3);
    }
}
