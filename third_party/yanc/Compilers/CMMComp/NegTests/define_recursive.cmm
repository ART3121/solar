#PRNAME p
#NUBITS 16
#NDSTAC 4
#SDEPTH 4
#NUIOIN 1
#NUIOOU 1
#NBMANT 10
#NBEXPO 5
#NUGAIN 128

// Negative fixture: a self-referential #define must NOT loop forever. The
// lexer's active-macro guard expands A exactly once to the text "A", which is
// then an undeclared variable -> a clean error, never a hang or a crash.
#define A A

void main()
{
    int x;
    x = A;
    out(0, x);
}
