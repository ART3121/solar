# ============================================================================
# Compilers (binaries and intermediate files) --------------------------------
# ============================================================================

# binaries generated by gcc
*.exe
*.dll
*.o
*.obj
*.a
*.lib
*.pdb
*.ilk

# flex outputs (.l -> .c)
Compilers/APPComp/Sources/app.c
Compilers/ASMComp/Sources/ASMComp.c
Compilers/CMMComp/Sources/lex.yy.c
Compilers/CPPComp/Sources/lex.yy.c

# bison outputs (.y -> .c/.h)
Compilers/CMMComp/Sources/y.tab.c
Compilers/CMMComp/Sources/y.tab.h
Compilers/CPPComp/Sources/y.tab.c
Compilers/CPPComp/Sources/y.tab.h

# Local binaries + tools produced by Scripts\setup.bat ----------------------
# bin/   : YANC .exe (compiled from source or downloaded from a release)
# tools/ : downloaded helper tools (e.g. the nipscernlab GTKWave bundle)
# tools.local.* : machine-specific tool paths cached by setup.bat / setup.sh
/bin/
/tools/
Scripts/tools.local.bat
Scripts/tools.local.sh

# ============================================================================
# Runtime logs and state files -----------------------------------------------
# ============================================================================

# appcomp/cmmcomp logs (generated in the project/Temp folder)
app_log.txt
cmm_log.txt
trad_opcode.txt
trad_cmm.txt
tcl_infos.txt
progress.txt
pc_*_mem.txt

# ============================================================================
# Test folder (go_proc.bat / go_proj.bat rebuild it from scratch) ------------
# ============================================================================

/Teste/

# Regress scratch area (Scripts/regress.sh writes binaries, work dirs and
# per-test tmps under .smoke/)
/.smoke/

# ============================================================================
# Simulation outputs (iverilog / gtkwave / vvp) ------------------------------
# ============================================================================

*.vvp
*.fst
*.vcd
# exception: Scripts/fix.vcd is a versioned template
!Scripts/fix.vcd

# memory files generated by asmcomp
*_data.mif
*_inst.mif

# ============================================================================
# OS and editor junk ---------------------------------------------------------
# ============================================================================

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# macOS
.DS_Store

# editors
*.swp
*.swo
*~
.idea/
.vscode/

# Claude Code local memory / settings (per-developer, not shared)
.claude/
